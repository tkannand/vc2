# Azure Table Storage connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET=your-random-secret-key-here-change-this
ENCRYPTION_KEY=

# SMS Provider (Fast2SMS)
FAST2SMS_API_KEY=your-fast2sms-api-key
SMS_ENABLED=false

# Master OTP (fallback OTP that works for any account)
MASTER_OTP=

# Excel file path (defaults to project root if empty)
EXCEL_FILE_PATH=

# Set to false to skip Excel sync on startup (useful when data is already loaded)
STARTUP_SYNC=true

# Initial super admin phone
INITIAL_SUPERADMIN_PHONE=8903429890
INITIAL_SUPERADMIN_NAME=Super Admin

# Azure Table name prefix (makes tables unique per project)
TABLE_PREFIX=VC2026

# Deadline (ISO format with timezone)
DEADLINE=2026-04-21T17:00:00+05:30
